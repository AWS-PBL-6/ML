{"$schema":"https://json-schema.org/draft/2020-12/schema","title":"AgentRequestV1","$comment":"Backend -> Agent-Based Response Layer input contract. Backend invokes the Response Guidance Lambda after a CAUTION/DANGER risk decision. Refs: aws-system-repository-and-interface-contract.md 6.2/7.3/8.1 (feature vocab rms/peakAmplitude/...), ml/inference-response.v1. camelCase, uppercase enum, UTC ISO8601.","type":"object","additionalProperties":false,"required":["schemaVersion","traceId","eventId","lineId","siteId","riskLevel"],"properties":{"schemaVersion":{"const":"1.0.0"},"traceId":{"type":"string","minLength":1},"eventId":{"type":"string","minLength":1},"requestId":{"type":"string"},"lineId":{"type":"string","minLength":1},"siteId":{"type":"string","minLength":1},"berthId":{"type":"string"},"bollardId":{"type":"string"},"vesselId":{"type":"string"},"riskLevel":{"type":"string","enum":["NORMAL","CAUTION","DANGER"]},"riskScore":{"type":"number","minimum":0,"maximum":1},"classProbabilities":{"type":"object","required":["NORMAL","CAUTION","DANGER"],"properties":{"NORMAL":{"type":"number","minimum":0,"maximum":1},"CAUTION":{"type":"number","minimum":0,"maximum":1},"DANGER":{"type":"number","minimum":0,"maximum":1}}},"modelVersion":{"type":"string"},"features":{"type":"object","description":"Evidence numbers (AE/structural-vibration features), arch 6.2 vocab; extra keys allowed.","properties":{"rms":{"type":"number"},"peakAmplitude":{"type":"number"},"energy":{"type":"number"},"dominantFrequencyHz":{"type":"number"},"riseTimeMs":{"type":"number"},"durationMs":{"type":"number"}}},"context":{"type":"object","description":"Material/tension/environment context; extra keys allowed (sensorKind, structuralFreqHz, loadRatio).","properties":{"materialType":{"type":"string"},"tensionEstimateKn":{"type":"number","minimum":0},"temperatureC":{"type":"number"},"humidityPct":{"type":"number","minimum":0,"maximum":100},"sensorKind":{"type":"string"},"structuralFreqHz":{"type":"number","minimum":0},"loadRatio":{"type":"number","minimum":0,"maximum":1},"windMps":{"type":"number","minimum":0},"craneActive":{"type":"integer","minimum":0,"maximum":1}}}}}
