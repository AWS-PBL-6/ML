{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Principal": {
        "Service": "bedrock.amazonaws.com"
      },
      "Action": "sts:AssumeRole",
      "Condition": {
        "StringEquals": {
          "aws:SourceAccount": "762616536500"
        },
        "ArnLike": {
          "aws:SourceArn": "arn:aws:bedrock:ap-northeast-2:762616536500:knowledge-base/*"
        }
      }
    }
  ]
}
